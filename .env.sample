# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Home Assistant ───────────────────────────────────────────────────────────
# Base URL of your Home Assistant instance (no trailing slash)
HASS_URL=http://homeassistant.local:8123
# Long-lived access token from HA profile → Security → Long-Lived Access Tokens
HASS_TOKEN=

# ── Obsidian ─────────────────────────────────────────────────────────────────
# Path to your Obsidian vault (defaults to ~/Documents/Obsidian if unset)
OBSIDIAN_VAULT=./vault

# ── Filesystem skill ─────────────────────────────────────────────────────────
# Comma-separated list of directories the filesystem skill is allowed to access.
# Defaults to OBSIDIAN_VAULT if unset. Add more paths as needed.
# ALLOWED_PATHS=~/Documents/Obsidian,~/Downloads

# ── Trello ───────────────────────────────────────────────────────────────────
# API key from https://trello.com/power-ups/admin
TRELLO_API_KEY=
# Token — visit: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=<YOUR_API_KEY>
TRELLO_TOKEN=

# ── Agent identity ───────────────────────────────────────────────────────────
# URL to the agent config JSON. Use file:///path/to/config.json or a GitHub raw path
# (owner/repo/refs/heads/branch/path) authenticated via GITHUB_PAT.
CONFIG_FILE_URL=
GITHUB_PAT=

# ── Google Calendar ──────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Refresh token — obtained via OAuth2 authorization flow
GOOGLE_REFRESH_TOKEN=

# ── Server ───────────────────────────────────────────────────────────────────
# Host and port for uvicorn (used by server.py)
HOST=0.0.0.0
PORT=8000

